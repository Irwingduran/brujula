# ============================
# Environment Variables (example)
# Copia este archivo a .env y completa los valores
# ============================

# Base de datos (PostgreSQL)
DATABASE_URL="postgresql://usuario@localhost:5432/brujula?schema=public"
DIRECT_URL="postgresql://usuario@localhost:5432/brujula?schema=public"

# Auth (NextAuth.js)
NEXTAUTH_SECRET="genera-uno-con: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Email (Brevo)
BREVO_API_KEY="tu-api-key"
FROM_EMAIL="tu@email.com"
FROM_NAME="Brújula"
ADMIN_NOTIFICATION_EMAIL="tu@email.com"

# WhatsApp Cloud API (Meta directa)
# Obtén estos valores desde https://developers.facebook.com → WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_FROM="" # ej: 521234567890 (sin +)

# IA
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-proj-..."
OPEN_ROUTER_KEY="sk-or-v1-..."
