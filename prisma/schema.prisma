// Prisma schema for Brújula Lead Generation System
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id                    String    @id @default(cuid())
  created_at            DateTime  @default(now())
  ultima_actividad_at   DateTime  @default(now()) @updatedAt

  // Contacto
  nombre                String
  email                 String
  telefono              String

  // Negocio
  industria             String
  tamano_empresa        String
  dolores_principales   String[]
  herramientas_actuales String[]
  descripcion_problema  String    @default("")
  url_sitio             String    @default("")
  website_analisis      Json?
  industria_otra        String?
  dolor_otro            String?
  herramienta_otra      String?
  evidencia_json        Json?
  formulario_version    String?
  contexto_externo_json Json?

  // Calificación
  presupuesto           String
  urgencia              String
  respuestas_branch     Json      @default("{}")
  respuestas_ia         String[]  @default([])

  // Generados por el sistema
  score                 Json?     // ScoreBreakdown completo
  diagnostico           Json?     // DiagnosisResult completo (estático)
  diagnostico_ia        Json?     // AIDiagnosisResult completo (generado por GPT-4o)
  briefing_profesional  Json?     // ProfessionalBriefing para el meet
  plan_desarrollo       Json?     // DevPlan para el admin/agencia

  // Pipeline
  segmento              String    @default("COLD")
  estado_pipeline       String    @default("wizard_completado")
  llamada_agendada_at   DateTime?
  enlace_reunion        String?   // Link de Meet/Zoom que el admin ingresa manualmente
  reunion_notificado_at DateTime? // Cuándo se notificó el link al lead
  notas_freelancer      String    @default("")
  notas_llamada         String?   // Feature: preferencia horaria del lead
  propuesta_enviada_at  DateTime? // Feature: cuándo se envió propuesta por email

  // Pipeline v2
  segmento_diagnostico  String?   // ej: "micro_retail", "pequena_servicios"
  madurez_digital       Int?      // 1–5
  perfil_riesgo         String?   // "alto" | "medio" | "bajo"
  sintomas_json         Json?     // output del paso 2 (lista de síntomas con scores)
  acciones_json         Json?     // output del paso 3 (acciones seleccionadas del catálogo)
  diagnostico_v2        Json?     // output del paso 5 (texto narrativo final)
  pipeline_version      String?   // "v2" — para distinguir diagnósticos nuevos de viejos
  pipeline_duration_ms  Int?      // ms totales del pipeline (para monitoreo)
  feedback_diagnostico    String?   // "positivo" | "negativo" — señal del prospecto
  feedback_diagnostico_at DateTime?

  // Tracking de comportamiento
  score_dinamico        Int       @default(0)
  emails_abiertos       Int       @default(0)
  visitas_propuesta     Int       @default(0)
  ultima_visita_at      DateTime?

  // Servicios (recomendaciones)
  servicios             LeadService[]
}

model Service {
  id                String    @id @default(cuid())
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  // Core
  name              String
  slug              String    @unique
  short_description String
  long_description  String    @default("")

  // Clasificación
  industries        String[]  // industrias a las que aplica
  category          String    // e.g., "ventas", "automatizacion", "atencion", "presencia_digital"
  pain_points       String[]  // dolores que resuelve
  tags              String[]  // @default([])

  // Detalles comerciales
  price_monthly     String?   // e.g., "$500 - $1,000 USD/mes"
  price_setup       String?   // Pago único de implementación
  timeline          String?   // e.g., "2-3 semanas"
  deliverables      String[]  // Qué incluye
  roi_estimate      String?   // e.g., "Incremento estimado de 25% en ventas"

  // Ventas
  case_study_title  String?
  case_study_text   String?

  // Control
  active            Boolean   @default(true)
  featured          Boolean   @default(false)
  sort_order        Int       @default(0)

  // Relations
  leads             LeadService[]
}

model User {
  id            String    @id @default(cuid())
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  name          String
  email         String    @unique
  password_hash String
  role          String    @default("admin") // "admin" | "superadmin"
  active        Boolean   @default(true)
  last_login_at DateTime?
}

model LeadService {
  lead_id     String
  service_id  String
  assigned_at DateTime  @default(now())
  assigned_by String    @default("pipeline") // "pipeline" | "admin"
  status      String    @default("suggested") // "suggested" | "approved" | "rejected" | "in_progress" | "completed"
  notes       String?

  lead    Lead    @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  service Service @relation(fields: [service_id], references: [id])

  @@id([lead_id, service_id])
}

model KnowledgeChunk {
  id         String    @id @default(cuid())
  contenido  String
  embedding  Unsupported("vector(1536)")
  industria  String
  segmento   String?
  tipo       String    // "sintoma" | "accion" | "benchmark" | "historia" | "pregunta_guia"
  fuente     String    // "fallback" | "knowledge_pack" | "generico" | "inegi" | "camara" | "auto_generado"
  activo     Boolean   @default(true)
  leadId     String?   // lead que generó este chunk (para filtrar por feedback)
  revisadoEn DateTime? // null = pendiente de revisión humana
  creadoEn   DateTime  @default(now())

  @@index([industria, segmento, tipo])
  @@index([activo])
  @@index([revisadoEn])
  @@index([leadId])
}
