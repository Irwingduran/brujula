// Prisma schema for Brújula Lead Generation System
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id                    String    @id @default(cuid())
  created_at            DateTime  @default(now())
  ultima_actividad_at   DateTime  @default(now()) @updatedAt

  // Contacto
  nombre                String
  email                 String
  telefono              String

  // Negocio
  industria             String
  tamano_empresa        String
  dolores_principales   String[]
  herramientas_actuales String[]
  descripcion_problema  String    @default("")
  url_sitio             String    @default("")
  website_analisis      Json?

  // Calificación
  presupuesto           String
  urgencia              String
  respuestas_branch     Json      @default("{}")
  respuestas_ia         String[]  @default([])

  // Generados por el sistema
  score                 Json?     // ScoreBreakdown completo
  diagnostico           Json?     // DiagnosisResult completo (estático)
  diagnostico_ia        Json?     // AIDiagnosisResult completo (generado por GPT-4o)
  briefing_profesional  Json?     // ProfessionalBriefing para el meet

  // Pipeline
  segmento              String    @default("COLD")
  estado_pipeline       String    @default("wizard_completado")
  llamada_agendada_at   DateTime?
  notas_freelancer      String    @default("")
  notas_llamada         String?   // Feature: preferencia horaria del lead
  propuesta_enviada_at  DateTime? // Feature: cuándo se envió propuesta por email

  // Pipeline v2
  segmento_diagnostico  String?   // ej: "micro_retail", "pequena_servicios"
  madurez_digital       Int?      // 1–5
  perfil_riesgo         String?   // "alto" | "medio" | "bajo"
  sintomas_json         Json?     // output del paso 2 (lista de síntomas con scores)
  acciones_json         Json?     // output del paso 3 (acciones seleccionadas del catálogo)
  diagnostico_v2        Json?     // output del paso 5 (texto narrativo final)
  pipeline_version      String?   // "v2" — para distinguir diagnósticos nuevos de viejos
  pipeline_duration_ms  Int?      // ms totales del pipeline (para monitoreo)

  // Tracking de comportamiento
  score_dinamico        Int       @default(0)
  emails_abiertos       Int       @default(0)
  visitas_propuesta     Int       @default(0)
  ultima_visita_at      DateTime?
}
